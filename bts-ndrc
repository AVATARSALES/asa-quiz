<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BTS NDRC en alternance — Avatar Sales Academy</title>
<meta name="description" content="La préparation au BTS NDRC pensée pour les alternants : Serious Games immersifs pour ancrer SPIN Selling, SONCAS et la digitalisation sans sacrifier ton temps libre.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800;900&family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --nuit:#0D1B35;
    --nuit-profonde:#08101F;
    --ardoise:#152949;
    --ardoise-clair:#1D3358;
    --ignition:#FF6B00;
    --ignition-clair:#FFA35C;
    --reacteur:#00AAFF;
    --craie:#F2EFE6;
    --craie-faible:rgba(242,239,230,0.62);
    --ligne:rgba(242,239,230,0.12);
    --danger:#FF4D5E;
    --ok:#38D9A9;
    --radius:14px;
    --wrap:1180px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important;}
  }
  body{
    margin:0;
    background:var(--nuit);
    color:var(--craie);
    font-family:'DM Sans',sans-serif;
    font-size:16px;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  img{max-width:100%;display:block;}
  a{color:inherit;}
  .wrap{max-width:var(--wrap);margin:0 auto;padding:0 28px;}
  h1,h2,h3,h4{
    font-family:'Barlow Condensed',sans-serif;
    font-weight:800;
    letter-spacing:0.01em;
    margin:0;
    line-height:1.05;
    text-transform:uppercase;
  }
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12.5px;
    letter-spacing:0.22em;
    text-transform:uppercase;
    color:var(--ignition);
    font-weight:600;
    display:inline-flex;
    align-items:center;
    gap:10px;
  }
  .eyebrow::before{
    content:"";
    width:22px;height:2px;
    background:var(--ignition);
    display:inline-block;
  }
  p.lead{font-size:1.1rem;color:var(--craie-faible);max-width:56ch;}
  .btn{
    display:inline-flex;
    align-items:center;
    gap:10px;
    font-family:'Barlow Condensed',sans-serif;
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:0.04em;
    font-size:1.02rem;
    padding:15px 30px;
    border-radius:8px;
    text-decoration:none;
    border:2px solid transparent;
    transition:transform .15s ease, box-shadow .15s ease;
    cursor:pointer;
  }
  .btn:hover{transform:translateY(-2px);}
  .btn:focus-visible{outline:3px solid var(--reacteur);outline-offset:3px;}
  .btn-primary{background:var(--ignition);color:var(--nuit-profonde);box-shadow:0 8px 24px rgba(255,107,0,0.25);}
  .btn-primary:hover{box-shadow:0 12px 30px rgba(255,107,0,0.4);}
  .btn-ghost{border-color:var(--ligne);color:var(--craie);}
  .btn-ghost:hover{border-color:var(--reacteur);}

  /* ---------- HEADER ---------- */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(8,16,31,0.86);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--ligne);
  }
  .nav{display:flex;align-items:center;justify-content:space-between;padding:16px 0;}
  .brand{display:flex;flex-direction:column;line-height:1;text-decoration:none;}
  .brand strong{font-family:'Barlow Condensed';font-weight:800;font-size:1.35rem;letter-spacing:0.02em;text-transform:uppercase;}
  .brand span{font-family:'JetBrains Mono';font-size:10.5px;letter-spacing:0.18em;color:var(--reacteur);text-transform:uppercase;margin-top:3px;}
  .nav-links{display:flex;align-items:center;gap:30px;list-style:none;margin:0;padding:0;}
  .nav-links a{
    font-family:'Barlow Condensed';font-weight:600;text-transform:uppercase;letter-spacing:0.03em;font-size:0.98rem;
    text-decoration:none;color:var(--craie-faible);transition:color .15s;
  }
  .nav-links a:hover{color:var(--ignition-clair);}
  .nav-cta{display:flex;align-items:center;gap:18px;}
  .burger{display:none;background:none;border:none;color:var(--craie);cursor:pointer;padding:6px;}
  @media (max-width:900px){
    .nav-links{position:fixed;top:69px;left:0;right:0;background:var(--nuit-profonde);flex-direction:column;align-items:flex-start;padding:22px 28px;gap:18px;border-bottom:1px solid var(--ligne);transform:translateY(-130%);transition:transform .25s ease;}
    .nav-links.open{transform:translateY(0);}
    .nav-cta .btn-primary{padding:11px 18px;font-size:0.9rem;}
    .burger{display:block;}
  }

  /* ---------- HERO ---------- */
  .hero{
    position:relative;
    padding:88px 0 70px;
    overflow:hidden;
    background:
      radial-gradient(ellipse 900px 500px at 85% -10%, rgba(0,170,255,0.18), transparent 60%),
      radial-gradient(ellipse 700px 500px at 5% 110%, rgba(255,107,0,0.14), transparent 60%),
      var(--nuit);
    border-bottom:1px solid var(--ligne);
  }
  .hero-grid{display:grid;grid-template-columns:1.1fr 0.9fr;gap:56px;align-items:center;}
  @media (max-width:940px){.hero-grid{grid-template-columns:1fr;}}
  .hero h1{font-size:clamp(2.5rem,5.4vw,4rem);margin:18px 0 22px;}
  .hero h1 em{font-style:normal;color:var(--ignition);}
  .hero-cta-row{display:flex;gap:16px;flex-wrap:wrap;margin-top:32px;}
  .hero-note{margin-top:16px;font-family:'JetBrains Mono';font-size:12px;color:var(--craie-faible);letter-spacing:0.03em;}

  /* HUD signature element */
  .hud{
    background:var(--nuit-profonde);
    border:1px solid var(--ligne);
    border-radius:16px;
    padding:26px 26px 22px;
    box-shadow:0 30px 60px rgba(0,0,0,0.35);
  }
  .hud-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;}
  .hud-title{font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.2em;color:var(--craie-faible);text-transform:uppercase;}
  .hud-live{display:flex;align-items:center;gap:7px;font-family:'JetBrains Mono';font-size:10.5px;color:var(--danger);letter-spacing:0.1em;}
  .hud-live::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--danger);animation:pulse 1.6s ease-in-out infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.25;}}
  .stat-row{margin-bottom:16px;}
  .stat-row:last-child{margin-bottom:0;}
  .stat-label{display:flex;justify-content:space-between;font-family:'JetBrains Mono';font-size:11.5px;letter-spacing:0.05em;color:var(--craie-faible);margin-bottom:6px;text-transform:uppercase;}
  .stat-label b{color:var(--craie);font-weight:600;}
  .meter{height:9px;border-radius:5px;background:rgba(242,239,230,0.08);overflow:hidden;}
  .meter i{
    display:block;height:100%;border-radius:5px;width:0%;
    transition:width 1.3s cubic-bezier(.2,.9,.25,1);
  }
  .meter.danger i{background:linear-gradient(90deg,#FF4D5E,#FF8A6B);}
  .meter.warn i{background:linear-gradient(90deg,var(--ignition),var(--ignition-clair));}
  .meter.info i{background:linear-gradient(90deg,#0077C2,var(--reacteur));}
  .hud.in-view .m1{width:18%;}
  .hud.in-view .m2{width:88%;}
  .hud.in-view .m3{width:34%;}
  .hud-foot{margin-top:20px;padding-top:16px;border-top:1px dashed var(--ligne);font-family:'JetBrains Mono';font-size:11px;color:var(--craie-faible);}
  .hud-foot b{color:var(--reacteur);}

  /* ---------- SECTION GENERIC ---------- */
  section{padding:86px 0;}
  .section-head{max-width:640px;margin-bottom:52px;}
  .section-head h2{font-size:clamp(1.9rem,3.6vw,2.8rem);margin-top:14px;}
  .section-head p{margin-top:16px;}
  .alt-bg{background:var(--nuit-profonde);border-top:1px solid var(--ligne);border-bottom:1px solid var(--ligne);}

  /* Constat cards */
  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  @media (max-width:900px){.grid-3{grid-template-columns:1fr;}}
  .card{
    background:var(--ardoise);
    border:1px solid var(--ligne);
    border-radius:var(--radius);
    padding:28px 26px;
  }
  .card .tag{font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--danger);}
  .card h3{font-size:1.5rem;margin:12px 0 10px;text-transform:none;}
  .card p{color:var(--craie-faible);font-size:0.98rem;margin:0;}

  /* VS comparatif */
  .vs-wrap{display:grid;grid-template-columns:1fr auto 1fr;gap:28px;align-items:stretch;}
  @media (max-width:820px){.vs-wrap{grid-template-columns:1fr;}.vs-badge{margin:8px auto;}}
  .vs-badge{
    align-self:center;
    font-family:'Barlow Condensed';font-weight:900;font-size:1.1rem;
    width:56px;height:56px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    background:var(--nuit);border:2px solid var(--ignition);color:var(--ignition);
  }
  .vs-col{border-radius:var(--radius);padding:30px 28px;border:1px solid var(--ligne);}
  .vs-old{background:var(--nuit-profonde);}
  .vs-new{background:linear-gradient(160deg, rgba(0,170,255,0.12), rgba(255,107,0,0.08)), var(--ardoise);border-color:rgba(0,170,255,0.35);}
  .vs-col .tag{font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.15em;text-transform:uppercase;}
  .vs-old .tag{color:var(--craie-faible);}
  .vs-new .tag{color:var(--reacteur);}
  .vs-col h3{font-size:1.7rem;margin:10px 0 18px;text-transform:none;}
  .vs-col ul{margin:0;padding:0;list-style:none;}
  .vs-col li{padding:10px 0;border-top:1px solid var(--ligne);font-size:0.97rem;color:var(--craie-faible);display:flex;gap:10px;}
  .vs-col li:first-child{border-top:none;}
  .vs-old li::before{content:"✕";color:var(--danger);font-weight:700;flex-shrink:0;}
  .vs-new li::before{content:"✓";color:var(--ok);font-weight:700;flex-shrink:0;}
  .vs-new li{color:var(--craie);}

  /* Feature grid (méthode) */
  .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;}
  @media (max-width:1000px){.grid-4{grid-template-columns:repeat(2,1fr);}}
  @media (max-width:560px){.grid-4{grid-template-columns:1fr;}}
  .feature{background:var(--nuit-profonde);border:1px solid var(--ligne);border-radius:var(--radius);padding:26px 22px;}
  .feature .ico{width:42px;height:42px;border-radius:10px;background:rgba(255,107,0,0.14);display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
  .feature .ico svg{width:22px;height:22px;stroke:var(--ignition);}
  .feature h3{font-size:1.28rem;text-transform:none;margin-bottom:8px;}
  .feature p{color:var(--craie-faible);font-size:0.94rem;margin:0;}

  /* Niveaux / épreuves */
  .levels{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  @media (max-width:940px){.levels{grid-template-columns:1fr;}}
  .level{
    position:relative;
    background:var(--ardoise);
    border:1px solid var(--ligne);
    border-radius:var(--radius);
    padding:30px 26px 26px;
    overflow:hidden;
  }
  .level::before{
    content:attr(data-n);
    position:absolute;top:-18px;right:-6px;
    font-family:'Barlow Condensed';font-weight:900;font-size:6.2rem;
    color:rgba(242,239,230,0.045);
    line-height:1;
  }
  .level .lvl-tag{font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.15em;color:var(--reacteur);text-transform:uppercase;}
  .level h3{font-size:1.55rem;margin:10px 0 12px;text-transform:none;position:relative;}
  .level p{color:var(--craie-faible);font-size:0.95rem;margin:0 0 16px;position:relative;}
  .chips{display:flex;flex-wrap:wrap;gap:8px;position:relative;}
  .chip{
    font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.03em;
    padding:5px 11px;border-radius:20px;
    background:rgba(255,107,0,0.12);color:var(--ignition-clair);
    border:1px solid rgba(255,107,0,0.3);
  }

  /* Fondateur */
  .founder{display:grid;grid-template-columns:0.55fr 1fr;gap:52px;align-items:center;}
  @media (max-width:900px){.founder{grid-template-columns:1fr;}}
  .founder-card{
    background:var(--nuit-profonde);border:1px solid var(--ligne);border-radius:20px;padding:34px;
    text-align:center;
  }
  .avatar-ring{
    width:132px;height:132px;border-radius:50%;margin:0 auto 20px;
    background:conic-gradient(from 220deg, var(--ignition), var(--reacteur), var(--ignition));
    display:flex;align-items:center;justify-content:center;padding:5px;
  }
  .avatar-ring .core{
    width:100%;height:100%;border-radius:50%;background:var(--nuit-profonde);
    display:flex;align-items:center;justify-content:center;
    font-family:'Barlow Condensed';font-weight:800;font-size:2rem;color:var(--craie);
  }
  .founder-card .years{font-family:'JetBrains Mono';font-size:12px;color:var(--craie-faible);letter-spacing:0.1em;text-transform:uppercase;}
  .founder-card .num{font-family:'Barlow Condensed';font-weight:900;font-size:2.6rem;color:var(--ignition);display:block;}
  .founder-text blockquote{margin:18px 0 0;padding-left:20px;border-left:3px solid var(--reacteur);font-style:normal;color:var(--craie);font-size:1.08rem;}
  .founder-text p{color:var(--craie-faible);}

  /* FAQ */
  .faq{max-width:820px;}
  details{
    border:1px solid var(--ligne);border-radius:12px;padding:18px 22px;margin-bottom:14px;
    background:var(--ardoise);
  }
  summary{
    cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:14px;
    font-family:'Barlow Condensed';font-weight:700;font-size:1.15rem;text-transform:none;
  }
  summary::-webkit-details-marker{display:none;}
  summary::after{content:"+";font-size:1.6rem;color:var(--ignition);flex-shrink:0;transition:transform .2s;}
  details[open] summary::after{transform:rotate(45deg);}
  details p{color:var(--craie-faible);margin:14px 0 0;font-size:0.97rem;}

  /* CTA final */
  .cta-final{
    text-align:center;
    background:
      radial-gradient(ellipse 800px 400px at 50% 0%, rgba(255,107,0,0.16), transparent 65%),
      var(--nuit-profonde);
    border-top:1px solid var(--ligne);
  }
  .cta-final .eyebrow{justify-content:center;}
  .cta-final .eyebrow::before{display:none;}
  .cta-final h2{font-size:clamp(2.2rem,5vw,3.4rem);margin:16px auto 18px;max-width:16ch;}
  .cta-final p{max-width:52ch;margin:0 auto 30px;color:var(--craie-faible);}
  .cta-final .hero-cta-row{justify-content:center;}

  /* Footer */
  footer{padding:52px 0 34px;border-top:1px solid var(--ligne);}
  .foot-grid{display:flex;justify-content:space-between;flex-wrap:wrap;gap:30px;margin-bottom:34px;}
  .foot-links{display:flex;gap:26px;flex-wrap:wrap;list-style:none;padding:0;margin:0;}
  .foot-links a{text-decoration:none;color:var(--craie-faible);font-size:0.92rem;}
  .foot-links a:hover{color:var(--reacteur);}
  .foot-bottom{border-top:1px solid var(--ligne);padding-top:22px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:0.85rem;color:var(--craie-faible);}
  .foot-bottom a{text-decoration:underline;}

  .reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease, transform .6s ease;}
  .reveal.is-visible{opacity:1;transform:none;}

  /* ---------- Galerie méthode (images plateforme) ---------- */
  .gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:44px;}
  @media (max-width:900px){.gallery{grid-template-columns:repeat(2,1fr);}}
  .gallery figure{margin:0;border:1px solid var(--ligne);border-radius:12px;overflow:hidden;background:var(--nuit-profonde);}
  .gallery img{width:100%;height:150px;object-fit:cover;display:block;}
  .gallery figcaption{padding:12px 14px;font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.06em;color:var(--craie-faible);text-transform:uppercase;}

  /* ---------- Vidéo ---------- */
  .video-wrap{max-width:820px;margin:0 auto;}
  .video-frame{position:relative;padding-top:56.25%;border-radius:16px;overflow:hidden;border:1px solid var(--ligne);box-shadow:0 30px 60px rgba(0,0,0,0.35);}
  .video-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0;}

  /* ---------- 6 blocs d'épreuves ---------- */
  .modules{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  @media (max-width:940px){.modules{grid-template-columns:repeat(2,1fr);}}
  @media (max-width:640px){.modules{grid-template-columns:1fr;}}
  .module-card{background:var(--ardoise);border:1px solid var(--ligne);border-radius:var(--radius);padding:24px 22px;position:relative;}
  .module-card .m-head{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
  .module-card .m-code{
    font-family:'Barlow Condensed';font-weight:900;font-size:1.5rem;
    width:46px;height:46px;border-radius:10px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    background:rgba(0,170,255,0.14);color:var(--reacteur);
  }
  .module-card.is-vente .m-code{background:rgba(255,107,0,0.16);color:var(--ignition);}
  .module-card h3{font-size:1.18rem;text-transform:none;line-height:1.2;}
  .module-card p{color:var(--craie-faible);font-size:0.92rem;margin:0;}
  .module-card .chip{margin-top:12px;display:inline-block;}

  .concepts{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px;}
  .concept-chip{
    font-family:'JetBrains Mono';font-size:12px;letter-spacing:0.03em;
    padding:9px 16px;border-radius:20px;
    background:var(--nuit-profonde);border:1px solid var(--ligne);color:var(--craie);
  }

  /* ---------- Tarifs ---------- */
  .pricing-tabs{display:grid;grid-template-columns:1fr 1fr;gap:32px;}
  @media (max-width:880px){.pricing-tabs{grid-template-columns:1fr;}}
  .price-card{
    background:var(--nuit-profonde);border:1px solid var(--ligne);border-radius:18px;
    padding:34px 30px;display:flex;flex-direction:column;
  }
  .price-card.highlight{border-color:rgba(255,107,0,0.4);background:linear-gradient(160deg, rgba(255,107,0,0.08), transparent), var(--nuit-profonde);}
  .price-card .p-tag{font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--reacteur);}
  .price-card.highlight .p-tag{color:var(--ignition);}
  .price-card h3{font-size:1.9rem;text-transform:none;margin:10px 0 6px;}
  .price-card .p-sub{color:var(--craie-faible);font-size:0.94rem;margin-bottom:20px;}
  .price-amount{display:flex;align-items:baseline;gap:8px;margin-bottom:6px;}
  .price-amount .num{font-family:'Barlow Condensed';font-weight:900;font-size:2.8rem;color:var(--craie);}
  .price-amount .per{font-family:'JetBrains Mono';font-size:12.5px;color:var(--craie-faible);}
  .price-note{font-family:'JetBrains Mono';font-size:11.5px;color:var(--craie-faible);margin-bottom:22px;}
  .price-list{list-style:none;padding:0;margin:0 0 26px;flex-grow:1;}
  .price-list li{padding:9px 0;border-top:1px solid var(--ligne);font-size:0.93rem;color:var(--craie-faible);display:flex;gap:9px;}
  .price-list li:first-child{border-top:none;}
  .price-list li::before{content:"✓";color:var(--ok);font-weight:700;flex-shrink:0;}
  .price-card .btn{justify-content:center;width:100%;}

  /* ---------- Partenaires / badges ---------- */
  .partners-strip{display:flex;align-items:center;justify-content:center;gap:46px;flex-wrap:wrap;opacity:0.85;}
  .partners-strip img{height:34px;width:auto;filter:grayscale(1) brightness(1.6);opacity:0.8;}
  .badges-row{display:flex;gap:18px;align-items:center;flex-wrap:wrap;}
  .badges-row img{height:46px;width:auto;border-radius:6px;}

  /* ---------- Avis (placeholder) ---------- */
  .placeholder-flag{
    display:inline-flex;align-items:center;gap:8px;
    font-family:'JetBrains Mono';font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
    color:var(--ignition-clair);background:rgba(255,107,0,0.1);border:1px dashed rgba(255,107,0,0.4);
    padding:6px 12px;border-radius:20px;margin-bottom:18px;
  }
  .reviews{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
  @media (max-width:940px){.reviews{grid-template-columns:repeat(2,1fr);}}
  @media (max-width:560px){.reviews{grid-template-columns:1fr;}}
  .review-card{background:var(--ardoise);border:1px solid var(--ligne);border-radius:var(--radius);padding:24px 22px;display:flex;flex-direction:column;}
  .review-stars{color:var(--ignition);font-size:0.95rem;letter-spacing:2px;margin-bottom:12px;}
